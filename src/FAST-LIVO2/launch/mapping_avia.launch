<launch>
  <arg name="rviz" default="false" />
  <arg name="republish_compressed" default="false" />
  <arg name="config_file" default="$(find fast_livo)/config/avia.yaml" />

  <rosparam command="load" file="$(arg config_file)" />

  <node pkg="fast_livo" type="fastlivo_mapping" name="laserMapping" output="screen">
    <rosparam file="$(find fast_livo)/config/camera_pinhole.yaml" />
  </node>

  <group if="$(arg republish_compressed)">
    <node pkg="image_transport"
          type="republish"
          name="republish"
          args="compressed in:=/left_camera/image raw out:=/left_camera/image"
          output="screen"
          respawn="true" />
  </group>

  <group if="$(arg rviz)">
    <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find fast_livo)/rviz_cfg/fast_livo2.rviz" />
  </group>
</launch>
